# LLM provider (default: Gemini)
# gemini | openai
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
# GEMINI_API_KEY=   # alias for GOOGLE_API_KEY
# Optional global model override (else provider default)
# LLM_MODEL=gemini-2.5-flash
#
# OpenAI fallback:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Agent service
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
# On Railway/Render, runtime PORT is injected automatically (agent honors PORT).
AGENT_BASE_URL=http://localhost:8000

# Web app (Vercel: set AGENT_BASE_URL + NEXT_PUBLIC_AGENT_BASE_URL to Railway URL)
# See docs/deploy-vercel.md
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:8000
# AGENT_BASE_URL=https://agent-production-1675.up.railway.app
# Used by next.config rewrites for /api/agent → agent (prefer over public URL at build time)

# CORS for the Next.js app (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: n8n PDF + email workflow (Phase 8)
# Set on the Next.js app (apps/web/.env.local) — server-side proxy only.
# Prefer production URL: https://<instance>.app.n8n.cloud/webhook/<id>
# Test URL (/webhook-test/...) only works while n8n is listening for a test event.
N8N_WEBHOOK_URL=

# Optional: Overpass / OSM (Phase 2)
# Live Overpass interpreter only (no local POI seed fallback in this capstone).
OVERPASS_API_URL=https://overpass.kumi.systems/api/interpreter
# OVERPASS_FALLBACK_URLS=https://overpass-api.de/api/interpreter,https://overpass.private.coffee/api/interpreter

# Optional: Open-Meteo weather (Phase 2)
OPEN_METEO_API_URL=https://api.open-meteo.com/v1/forecast

# Optional: Orchestrator LLM planner (multi-agent routing)
# Uses Gemini/OpenAI when the matching API key is set.
# Set ORCHESTRATOR_LLM=false to force heuristic routing only.
ORCHESTRATOR_LLM=true
# ORCHESTRATOR_MODEL=gemini-2.5-flash

# Optional: Synthesis / Presentation Agent narrative polish (no itinerary changes)
SYNTHESIS_LLM=true
# SYNTHESIS_MODEL=gemini-2.5-flash
# Legacy alias still honored:
# MERGER_LLM=true

# Optional: Itinerary Agent LLM optimizer (move/skip/reorder)
ITINERARY_LLM=true
# ITINERARY_MODEL=gemini-2.5-flash
# Itinerary selection: legacy (default diversify fill) or hybrid (shortlist+quotas+clusters)
ITINERARY_STRATEGY=legacy

# Optional: Reviewer LLM layer
REVIEWER_LLM=true
# REVIEWER_MODEL=gemini-2.5-flash

# huggingface = local BGE (free; heavy on Railway — prefer bm25 there)
# openai | bm25 | auto (OpenAI if key set, else BM25)
# Railway default in Dockerfile: RAG_EMBEDDINGS=bm25
RAG_EMBEDDINGS=huggingface
RAG_HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Google Places API for Jaipur RAG place cards (no HTML scrape)
# Fetcher default cap is 900 unique places (Text Search New; billed per request).
# Day-by-day append: python -m agent.rag.fetch_google_places --merge --pack museums --max-places 3000
# Packs: named | museums | temples | gardens | heritage | restaurants | cafes | nightlife | markets | hotels | neighborhoods
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=   # alias also accepted

# Optional: speech-to-text model for /stt (defaults to LLM_MODEL / provider default)
# STT_MODEL=gemini-2.5-flash

# Multi-agent workflow mode (default true): fixed waves for plan/edit/explain.
# Set false to allow LLM orchestration for plan turns (requires ORCHESTRATOR_LLM=true).
AGENT_WORKFLOW_MODE=true
